{
  "name": "scriptable",
  "version": "1.0.0",
  "description": "Collection of Scriptable helper scripts (internal and for Shortcuts).",
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fourjuaneight/scriptable.git"
  },
  "keywords": [
    "shortcuts",
    "scriptable"
  ],
  "author": "Juan Villela",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fourjuaneight/scriptable/issues"
  },
  "homepage": "https://github.com/fourjuaneight/scriptable#readme",
  "scripts": {
    "clean:node": "rm -rf node_modules",
    "format": "prettier --write \"*.js\"",
    "lint": "eslint --fix \"*.js\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "pnpm lint",
      "pnpm format"
    ]
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3"
  }
}
